<Window x:Class="tebenkova_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:tebenkova_wpf.Converters"
        Title="ООО Цветы Прикамья - Система учета партнеров" 
        Height="750" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        WindowState="Maximized">

    <Window.Resources>
        <converters:DiscountToColorConverter x:Key="DiscountToColorConverter"/>

        <!-- Стиль для кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для текстового поля поиска -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков вкладок -->
        <Style x:Key="TabHeaderStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid x:Name="root">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="Transparent"
                                    CornerRadius="6,6,0,0">
                                <ContentPresenter x:Name="content" 
                                                ContentSource="Header"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="15,8"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4CAF50"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#4CAF50"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8F5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEEEEE"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка с логотипом -->
        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="8" 
                Padding="15" 
                Margin="0,0,0,10"
                BorderBrush="#DDDDDD"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <Border Grid.Column="0" 
                        Background="#4CAF50" 
                        Width="50" Height="50" 
                        CornerRadius="25"
                        HorizontalAlignment="Left">
                    <TextBlock Text="🌿" 
                               FontSize="28" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </Border>

                <!-- Название -->
                <StackPanel Grid.Column="1" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center"
                            Margin="20,0">
                    <TextBlock Text="ООО Цветы Прикамья" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#2E7D32"/>
                    <TextBlock Text="Система учета партнеров и расчета скидок" 
                               FontSize="13" 
                               Foreground="#666666"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Дата и время -->
                <StackPanel Grid.Column="2" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="TxtCurrentDate" 
                               Text="13.03.2026" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#2E7D32"/>
                    <TextBlock x:Name="TxtCurrentTime" 
                               Text="14:30:25" 
                               FontSize="13" 
                               Foreground="#666666"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" 
                    x:Name="MainTabControl"
                    Margin="0,0,0,10"
                    Background="Transparent"
                    BorderThickness="0">
            <TabItem Header="📋 Партнеры" Style="{StaticResource TabHeaderStyle}" IsSelected="True"/>
            <TabItem Header="📦 Товары" Style="{StaticResource TabHeaderStyle}"/>
            <TabItem Header="📊 Склад" Style="{StaticResource TabHeaderStyle}"/>
            <TabItem Header="📈 Отчеты" Style="{StaticResource TabHeaderStyle}"/>
        </TabControl>

        <!-- Контейнер для содержимого вкладок -->
        <ContentControl Grid.Row="2" x:Name="TabContentArea"/>

        <!-- Статус бар -->
        <StatusBar Grid.Row="3" 
                   Background="White" 
                   Height="32" 
                   Margin="0,10,0,0"
                   BorderBrush="#DDDDDD"
                   BorderThickness="1"
                   >
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TxtStatus" Text="Готов к работе" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Производственная практика 2026 | ООО Цветы Прикамья" 
                           FontSize="10" 
                           Foreground="#999999"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>