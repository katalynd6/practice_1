<Window x:Class="tebenkova_wpf.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" 
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#4CAF50" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" 
                       Text="Добавление товара" 
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Артикул:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <TextBox x:Name="TxtArticle" Height="35" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Наименование:" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtName" Height="35" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Категория:" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbCategory" Height="35" Margin="0,0,0,10">
                    <ComboBoxItem Content="Цветы"/>
                    <ComboBoxItem Content="Горшки"/>
                    <ComboBoxItem Content="Удобрения"/>
                    <ComboBoxItem Content="Инструмент"/>
                    <ComboBoxItem Content="Декор"/>
                </ComboBox>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Цена:" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtPrice" Height="35" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="На складе:" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtStock" Height="35" Padding="5"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="BtnSave" 
                    Content="Сохранить" 
                    Width="100" Height="35" Margin="5" 
                    Background="#4CAF50" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0"
                    Click="BtnSave_Click"/>

            <Button x:Name="BtnCancel" 
                    Content="Отмена" 
                    Width="100" Height="35" Margin="5" 
                    Background="#F44336" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>