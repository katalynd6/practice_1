<Window x:Class="tebenkova_wpf.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнера" 
        Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#4CAF50" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" 
                       Text="Добавление партнера" 
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Поля ввода -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Тип партнера:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                <ComboBox x:Name="CmbPartnerType" 
                          Height="35" Margin="0,0,0,10" 
                          DisplayMemberPath="Name" 
                          SelectedValuePath="Id"/>

                <TextBlock Text="Наименование:" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtName" Height="35" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Юридический адрес:" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtAddress" Height="35" Margin="0,0,0,10" Padding="5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="ИНН:" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtINN" MaxLength="12" Height="35" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Рейтинг (0-10):" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtRating" Text="0" MaxLength="2" Height="35" Padding="5"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="ФИО директора:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <TextBox x:Name="TxtDirector" Height="35" Margin="0,0,0,10" Padding="5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Телефон:" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtPhone" Height="35" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Email:" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtEmail" Height="35" Padding="5"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="BtnSave" 
                    Content="Сохранить" 
                    Width="100" Height="35" Margin="5" 
                    Background="#4CAF50" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0"
                    Click="BtnSave_Click"/>

            <Button x:Name="BtnCancel" 
                    Content="Отмена" 
                    Width="100" Height="35" Margin="5" 
                    Background="#F44336" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>